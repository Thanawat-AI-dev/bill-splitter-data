rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /billProjects/{projectId} {
      function signedIn() {
        return request.auth != null;
      }

      function isOwner() {
        return signedIn()
          && resource.data.project.ownerUid == request.auth.uid;
      }

      function createsOwnProject() {
        return signedIn()
          && request.resource.data.project.ownerUid == request.auth.uid;
      }

      function guestOnlyChangedSplitState() {
        return signedIn()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['project', 'entry', 'lastGuestMessage'])
          && request.resource.data.project.diff(resource.data.project).affectedKeys()
            .hasOnly(['shares', 'doneBy', 'updatedAt']);
      }

      allow read: if signedIn();
      allow create: if createsOwnProject();
      allow update: if isOwner() || guestOnlyChangedSplitState();
      allow delete: if isOwner();
    }
  }
}
